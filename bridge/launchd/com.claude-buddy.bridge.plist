<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.claude-buddy.bridge</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/john/.pio-venv/bin/python</string>
    <string>-u</string>
    <string>/Users/john/alibaba/s3stick/bridge/buddy_bridge.py</string>
  </array>

  <!-- Start at login and keep it alive (restart on crash/exit). -->
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>5</integer>

  <key>ProcessType</key>
  <string>Background</string>

  <key>StandardOutPath</key>
  <string>/Users/john/.claude-buddy/bridge.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/john/.claude-buddy/bridge.err</string>
</dict>
</plist>
